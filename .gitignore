```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.pyo
*.pyd
*.so
*.egg-info/

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Coverage reports
.coverage
coverage/
htmlcov/

# Editors/IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
```